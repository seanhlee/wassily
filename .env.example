# Cloud collaboration placeholders.
# The app stays local-first without these values. Fill them after creating the
# Clerk, Convex, and Cloudflare/R2 projects.

# Enables cloud UI/provider wiring once Clerk + Convex are configured.
VITE_WASSILY_CLOUD_ENABLED=false

# Clerk publishable key for browser auth.
VITE_CLERK_PUBLISHABLE_KEY=

# Convex deployment URL for realtime board state.
VITE_CONVEX_URL=

# Cloudflare account and private R2 bucket used by server-side upload/signing
# functions. The browser does not read these values.
CLOUDFLARE_ACCOUNT_ID=
R2_BUCKET_NAME=
